<GameScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: 20
        spacing: 20

        # ส่วนบน: กระดานไพ่ผลไม้ (ใช้ FloatLayout เพื่อวางไพ่แบบอิสระ)
        FloatLayout:
            id: game_board
            size_hint_y: 0.7
            canvas.before:
                Color:
                    rgba: 0.95, 0.95, 0.95, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Label:
                text: root.time_display  # ผูกกับตัวแปร time_display ใน Python
                font_size: '30sp'
                color: 1, 0, 0, 1  # สีแดง
                pos_hint: {'center_x': 0.85, 'top': 0.95} # มุมขวาบน
                bold: True

        # ส่วนล่าง: ช่องเก็บไพ่ 7 ช่อง (ที่กดลงมาแล้วรอจับคู่ 3 ใบ)
        BoxLayout:
            size_hint_y: 0.3
            orientation: 'vertical'
            spacing: 5
            canvas.before:
                Color:
                    rgba: 0.8, 0.8, 0.8, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
            
            # แสดงจำนวนช่องว่าง
            Label:
                text: root.slot_display
                color: 0, 0, 0, 1
                size_hint_y: 0.3
                font_size: '18sp'
                bold: True
            
            # แสดงไพ่ที่เก็บไว้
            Label:
                text: ' | '.join(root.slot_fruits) if root.slot_fruits else 'ยังไม่มีไพ่'
                color: 0.2, 0.2, 0.8, 1
                size_hint_y: 0.7
                font_size: '16sp'